/* widget-configs/clock.json - Clock Widget Configuration */
{
    "name": "Clock Widget",
    "description": "Real-time clock with optional date and timezone support",
    "type": "standard",
    "default_width": 120,
    "default_height": 32,
    "mandatory": false,
    "position": "center",
    "properties": {
        "format": "24h",
        "show_seconds": false,
        "show_date": true,
        "timezone": "UTC",
        "update_frequency": 1000,
        "use_nerd_font": true
    },
    "theme": {
        "text_color": "#cdd6f4",
        "background_alpha": 0.0,
        "text_size": 12,
        "bold_text": true
    }
}
