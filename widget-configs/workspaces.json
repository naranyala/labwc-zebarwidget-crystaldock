/* widget-configs/workspaces.json - Workspaces Widget Configuration */
{
    "name": "Workspace Switcher",
    "description": "Navigate between workspaces with visual indicators and click support",
    "type": "standard",
    "default_width": 280,
    "default_height": 32,
    "mandatory": false,
    "position": "left",
    "properties": {
        "count": 9,
        "show_active": true,
        "click_action": "switch",
        "hover_preview": true,
        "animation": "fade",
        "keyboard_navigation": true
    },
    "theme": {
        "active_bg": "#89b4fa",
        "active_bg_alpha": 0.2,
        "text_color": "#cdd6f4",
        "border_color": "#585b70",
        "text_size": 10,
        "button_width": 28,
        "button_height": 20
    }
}
