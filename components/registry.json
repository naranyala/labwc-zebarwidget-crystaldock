{
  "$schema": "./registry-schema.json",
  "version": "1.0.0",
  "description": "C-based Wayland-native widget and statusbar components",
  "statusbars": {
    "main": {
      "name": "Main Statusbar",
      "binary": "statusbar-main",
      "description": "Full-featured statusbar with all widgets",
      "widgets": ["clock", "cpu", "memory", "network", "battery", "volume"],
      "position": "top",
      "height": 32,
      "exclusive_zone": 32
    },
    "compact": {
      "name": "Compact Bar",
      "binary": "statusbar-compact",
      "description": "Space-optimized single-line bar",
      "widgets": ["clock", "cpu", "memory"],
      "position": "top",
      "height": 24,
      "exclusive_zone": 24
    },
    "panel": {
      "name": "Dashboard Panel",
      "binary": "statusbar-panel",
      "description": "Grid dashboard with detailed metrics",
      "widgets": ["cpu", "memory", "network", "battery"],
      "position": "bottom",
      "height": 200,
      "exclusive_zone": 200
    }
  },
  "widgets": {
    "clock": {
      "name": "Clock",
      "binary": "widget-clock",
      "description": "Real-time clock with date",
      "providers": ["date"],
      "default_width": 120,
      "default_height": 32
    },
    "cpu": {
      "name": "CPU Monitor",
      "binary": "widget-cpu",
      "description": "CPU usage monitor",
      "providers": ["cpu"],
      "default_width": 80,
      "default_height": 32
    },
    "memory": {
      "name": "Memory Monitor",
      "binary": "widget-memory",
      "description": "Memory usage monitor",
      "providers": ["memory"],
      "default_width": 80,
      "default_height": 32
    },
    "network": {
      "name": "Network Status",
      "binary": "widget-network",
      "description": "Network connectivity status",
      "providers": ["network"],
      "default_width": 120,
      "default_height": 32
    },
    "battery": {
      "name": "Battery",
      "binary": "widget-battery",
      "description": "Battery level and charging status",
      "providers": ["battery"],
      "default_width": 80,
      "default_height": 32
    },
    "volume": {
      "name": "Volume",
      "binary": "widget-volume",
      "description": "Audio volume control",
      "providers": ["volume"],
      "default_width": 80,
      "default_height": 32
    }
  },
  "docks": {
    "crystal": {
      "name": "Crystal Dock",
      "binary": "crystal-dock",
      "args": ["--start", "--overlay"],
      "description": "Wayland dock with app launchers"
    },
    "none": {
      "name": "No Dock",
      "binary": null,
      "description": "No dock panel"
    }
  },
  "themes": {
    "default": "catppuccin-mocha",
    "available": ["catppuccin-mocha", "nord", "dracula", "tokyo-night"]
  }
}
