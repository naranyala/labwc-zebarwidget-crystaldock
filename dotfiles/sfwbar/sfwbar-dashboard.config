#Api2

# SFWBar — Dashboard-style bar with all widgets
# Maximum information, floating panel style
Theme = "Adwaita-dark"
Set ImagePath = "icons/misc:icons/weather"
Set ThicknessHint = "40px"

switcher { disable = true }

Function SfwbarInit() {}

bar {
  edge = "top"
  layer = "top"
  mirror = "*"
  exclusive_zone = "auto"

  # --- Left: Navigation ---
  widget "launcher.widget"
  widget "workspaces.widget"
  widget "keyboard-layout.widget"

  # --- Center: Clock + Weather ---
  label { css = "* { -GtkWidget-hexpand: true; }" }
  widget "clock.widget"
  widget "weather.widget"
  label { css = "* { -GtkWidget-hexpand: true; }" }

  # --- Right: Full System Stack ---
  widget "media-player.widget"
  widget "tray.widget"
  widget "privacy.widget"
  widget "network-monitor.widget"
  widget "bluetooth-monitor.widget"
  widget "volume-control.widget"
  widget "brightness.widget"
  widget "nightlight.widget"
  widget "idle-inhibit.widget"
  widget "cpu-monitor.widget"
  widget "memory-monitor.widget"
  widget "disk.widget"
  widget "temperature.widget"
  widget "battery-monitor.widget"
  widget "power-profile.widget"
  widget "sysmon.widget"
  widget "clipboard.widget"
  widget "session.widget"
}
