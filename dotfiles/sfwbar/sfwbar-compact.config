#Api2

# SFWBar — Compact bar with essential widgets only
# Minimal footprint, maximum information density
Theme = "Adwaita-dark"
Set ImagePath = "icons/misc:icons/weather"
Set ThicknessHint = "28px"

switcher { disable = true }

Function SfwbarInit() {}

bar {
  edge = "top"
  layer = "top"
  mirror = "*"
  exclusive_zone = "auto"

  # --- Left: Launcher ---
  widget "launcher.widget"

  # --- Center: Clock ---
  label { css = "* { -GtkWidget-hexpand: true; }" }
  widget "clock.widget"
  label { css = "* { -GtkWidget-hexpand: true; }" }

  # --- Right: Compact modules ---
  widget "media-player.widget"
  widget "tray.widget"
  widget "network-monitor.widget"
  widget "volume-control.widget"
  widget "battery-monitor.widget"
  widget "session.widget"
}
