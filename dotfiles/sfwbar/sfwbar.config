#Api2

# Dark theme
Theme = "Adwaita-dark"
Css = "catppuccin-mocha.css"

# Icon paths
Set ImagePath = "icons/misc:icons/weather"

# Bar thickness
Set ThicknessHint = "32px"

# Disable task switcher
TriggerAction "SIGRTMIN+1", SwitcherEvent("forward");
TriggerAction "SIGRTMIN+2", SwitcherEvent("back");

switcher {
  disable = true
}

# Window placer
placer {
  xorigin = 5
  yorigin = 5
  xstep = 5
  ystep = 5
  children = true
}

Function SfwbarInit() {
}

# Main bar - TOP, no taskbar
bar {
  edge = "top"
  layer = "top"
  mirror = "*"
  exclusive_zone = "auto"

  # Workspaces - 2 only
  pager {
    style = "pager"
    rows = 1
    pins = "1","2"
    preview = true
    primary_axis = rows
    action[Drag] = WorkspaceActivate()
  }

  # Taskbar - DISABLED
  taskbar {
    disable = true
  }

  # Spacer
  label {
    css = "* { -GtkWidget-hexpand: true; }"
  }

  # Clock
  widget "clock.widget" {
    disable = false
    time_format = "%H:%M"
    tooltip_format = "%A %d %B %Y\n%H:%M:%S"
    week_starts_on_sunday = false
    reset_on_popup = false
  }

  # System tray
  tray {
    rows = 1
  }

  # Text widgets
  widget "cpu-text.widget"
  widget "memory-text.widget"
  widget "network-text.widget"
  widget "volume-text.widget"
  widget "battery-text.widget"

  # Session menu
  widget "session.widget" {
    session_actions = [
      ["system-lock-screen", "Lock", "loginctl lock-session"],
      ["system-log-out", "Logout", "loginctl terminate-user $USER"],
      ["system-reboot", "Reboot", "systemctl reboot"],
      ["system-shutdown", "Shutdown", "systemctl poweroff"]
    ]
  }
}

# ============================================================================
# CSS - Dark Mode
# ============================================================================

* {
  background-color: #1e1e2e;
  color: #cdd6f4;
}

button, button image {
  min-height: 0px;
  outline-style: none;
  box-shadow: none;
  background-image: none;
  border-image: none;
  background-color: transparent;
  color: #cdd6f4;
}

label {
  font-family: 'JetBrains Mono', 'Fira Code', monospace;
  font-size: 12px;
  color: #cdd6f4;
  background-color: transparent;
}

image {
  -ScaleImage-symbolic: true;
  color: #cdd6f4;
}

.module {
  border: none;
  padding: 4px 8px;
  margin: 0px;
  -GtkWidget-vexpand: true;
  background-color: rgba(69, 71, 90, 0.4);
}

.module:hover {
  background-color: rgba(69, 71, 90, 0.6);
}

.focused {
  background-color: rgba(137, 180, 250, 0.3);
}

.urgent label {
  color: #f38ba8;
}

# Text widgets
label#cpu-text, label#memory-text, label#network-text,
label#volume-text, label#battery-text {
  padding: 4px 8px;
  background-color: rgba(69, 71, 90, 0.4);
  color: #cdd6f4;
  border-radius: 4px;
  margin: 2px;
}

label#cpu-text:hover, label#memory-text:hover, label#network-text:hover,
label#volume-text:hover, label#battery-text:hover {
  background-color: rgba(69, 71, 90, 0.6);
}

# Pager
grid#pager {
  border-radius: 4px;
  border-color: #585b70;
  border-style: solid;
  border-width: 1px;
  margin: 4px;
  padding: 0px;
  background-color: transparent;
}

button#pager_item {
  border-radius: 4px;
  border: none;
  outline: 0px;
  margin-right: 2px;
  margin-left: 2px;
  padding: 0px;
  -GtkWidget-halign: center;
  -GtkWidget-valign: center;
  background-color: transparent;
}

button#pager_item label {
  font-size: 11px;
  color: #585b70;
}

button#pager_item.active label {
  color: #cdd6f4;
  font-weight: bold;
}

button#pager_item.occupied label {
  color: #a6adc8;
}

button#pager_item:hover {
  background-color: rgba(69, 71, 90, 0.6);
}

# Tray
button#tray_item {
  margin: 0px;
  border: none;
  padding: 0px;
  background-color: transparent;
}

button#tray_item.passive {
  -GtkWidget-visible: false;
}

button#tray_item image {
  -GtkWidget-valign: center;
  -GtkWidget-vexpand: true;
  padding: 3px;
  margin: 0px;
}

# Menu
menu {
  background-color: #313244;
  color: #cdd6f4;
}

menuitem {
  background-color: #313244;
  color: #cdd6f4;
}

menuitem:hover {
  background-color: #45475a;
}

# Tooltip
tooltip {
  background-color: #313244;
  color: #cdd6f4;
}

tooltip label {
  color: #cdd6f4;
}
