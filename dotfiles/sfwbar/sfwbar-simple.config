# Simple SFWBar configuration for testing

# Api2

# Disabled theme override

# Icon search path
Set ImagePath = "icons/misc"

# Bar thickness hint
Set ThicknessHint = "32px"

# Display minimized windows on taskbars across all outputs
# DisownMinimized = true

TriggerAction "SIGRTMIN+1", SwitcherEvent("forward");
TriggerAction "SIGRTMIN+2", SwitcherEvent("back");

Function SfwbarInit() {
}

# Main bar ( minimalist - just text info ) 
bar {
  edge = "top"
  layer = "top"
  mirror = "*"
  exclusive_zone = "auto"

  # Pager (workspace buttons) - disabled for simplicity
  pager {
    disable = true
  }

  # System info panel
  widget "cpu.widget"
  widget "memory.widget"
  widget "network.widget"

  # Clock
  widget "clock.widget" {
    disable = false
    time_format = "%H:%M:%S"
    tooltip_format = "%A %d %B %Y\n%H:%M:%S"
    week_starts_on_sunday = false
    reset_on_popup = false
  }
}
