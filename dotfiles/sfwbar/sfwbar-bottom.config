#Api2

# SFWBar — Bottom Panel (Taskbar + System Tray)
Theme = "Adwaita-dark"
Set ImagePath = "icons/misc:icons/weather"
Set ThicknessHint = "34px"

bar "bottombar" {
  edge = "bottom"
  layer = "top"
  mirror = "*"
  exclusive_zone = "auto"

  # --- Left: Quick Launch ---
  widget "launcher.widget"

  # --- Center: Taskbar ---
  taskbar {
    style = "taskbar"
    rows = 1
    icons = true
    labels = true
    tooltips = true
    sort = false
    css = "* { -GtkWidget-hexpand: true; }"
  }

  # --- Right: System Tray + Clock ---
  widget "tray.widget"
  widget "clock.widget"
}

#CSS
/* Bottom bar — fixed, full width */
window#sfwbar {
  background-color: rgba(30, 30, 46, 0.85);
  border-radius: 0px;
  margin: 0px;
  border-top: 1px solid rgba(88, 91, 112, 0.3);
}

button#taskbar_item {
  padding: 4px 8px;
  margin: 2px;
  border-radius: 6px;
  background-color: transparent;
}

button#taskbar_item:hover {
  background-color: rgba(69, 71, 90, 0.5);
}

button#taskbar_item.focused {
  background-color: rgba(137, 180, 250, 0.2);
}

button#taskbar_item.urgent {
  background-color: rgba(243, 139, 168, 0.2);
}

button#taskbar_item image {
  min-height: 20px;
  min-width: 20px;
  padding: 2px;
}

button#taskbar_item label {
  font-size: 11px;
  padding-left: 4px;
}
