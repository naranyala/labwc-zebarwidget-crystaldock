#Api2

# Renderer: use the glib-free zigshell instead of zigshell-cairo-pango
Shell = "zigshell-cairo-pango"
# single.mode — Single statusbar (all-in-one top bar)

# --- Common Infrastructure ---
include("../ocws.config")

# --- Bar ---
bar "statusbar:top" {
  edge = "top"
  layer = "top"
  mirror = "*"
  exclusive_zone = "auto"
  size = $OCWS_BAR_THICKNESS

  include("../widget-sets/single.set")
}
