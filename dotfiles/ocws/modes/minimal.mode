#Api2

# Renderer: use the glib-free zigshell instead of zigshell-cairo-pango
Shell = "zigshell-cairo-pango"
# minimal.mode — Minimal status bar (clock, volume, battery, tray)

switcher { disable = true }

# --- Common Infrastructure ---
include("../ocws.config")

# --- Minimal Bar ---
bar {
  edge = "top"
  layer = "top"
  mirror = "*"
  exclusive_zone = "auto"
  size = 28

  include("../widget-sets/minimal.set")
}
