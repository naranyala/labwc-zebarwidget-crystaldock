#Api2

# Renderer: use the glib-free zigshell instead of zigshell-cairo-pango
Shell = "zigshell-cairo-pango"
# compact.mode — Single bar with integrated taskbar + dock icons

# --- Common Infrastructure ---
include("../ocws.config")

# --- Compact Bar ---
bar "compactbar:top" {
  edge = "top"
  layer = "top"
  mirror = "*"
  exclusive_zone = "auto"
  size = 36

  include("../widget-sets/compact.set")
}
