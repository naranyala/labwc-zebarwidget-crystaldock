# Build artifacts
build/
result
result-*
.zig-cache/
zig-out/
zig-cache/
CMakeFiles/

# Recursively ignore any build/ output dirs (per-shell Zig builds, deps, etc.)
**/build/
**/.zig-cache/
**/zig-out/

# Nested build caches
src/shells/zigshell-cairo-pango/.zig-cache/
src/shells/zigshell-cairo-pango/zig-out/

# Source clones (upstream repos, not tracked)
sources/

# Debian packages
*.deb

# Archives
*.tar.gz
*.tar.xz
*.zip

# Compiled objects and binaries
*.o
*.so
*.dylib

# Editor/IDE
.vscode/
.idea/
.vscode-test/
*.swp
*.swo
*~
.cache/
*.bak

# OS files
.DS_Store
Thumbs.db
desktop.ini

# Logs
*.log

# Environment
.env
.env.*

# Node (if used for widget dev)
node_modules/
package-lock.json

# Python
__pycache__/
*.pyc

# Temp files
/tmp/
*.tmp
*.temp

# Download cache
/tmp/theme-downloads/

# User-specific configs
current-theme

# Downloaded theme resources (use download-themes.sh)
themes/download-cache/

# AI Models and Python Environments
*.gguf
*.safetensors
*.bin
models/
.venv/
venv/
*.egg-info/
dist/

# MkDocs build output
www/site/
